############ REQUIRED ############
OP_GROUP_BOT_ID=
TG_REST_BOT_TOKEN=
TG_REST_CHANNEL_ID=

# Password to access the dashboard. Change this anytime to rotate it - no redeploy of code needed
DASHBOARD_PASSWORD=

# Telegram Client API credentials from https://my.telegram.org/apps, required by Telethon
TG_API_ID=
TG_API_HASH=

DB_NAME=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=

############ OPTIONAL ############
DB_LOG_QUERIES=

# Telethon StringSession for the TG Rest Bot. Only needed on hosts with a non-persistent
# filesystem; leave empty to use a local session file instead
TG_REST_SESSION_STRING=

TZ=

REFUND_WAGER_DEFAULT=
ALLOW_MULTIPLE_CHOICES_DEFAULT=
CAN_WITHDRAW_BET_DEFAULT=

DEVIL_FRUIT_MIN_ABILITY_VALUE=
DEVIL_FRUIT_MAX_ABILITY_VALUE=
DEVIL_FRUIT_CATEGORY_ZOAN_SUM=
DEVIL_FRUIT_CATEGORY_ANCIENT_ZOAN_SUM=
DEVIL_FRUIT_CATEGORY_MYTHICAL_ZOAN_SUM=

MAX_ITEMS_DISPLAYED_LIST=

MAX_WARLORDS=

MAX_LEGENDARY_PIRATES=